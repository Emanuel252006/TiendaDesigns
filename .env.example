# =========================
# APP / DEPLOY
# =========================
NODE_ENV=production
PORT=3001

# Dominio publico del backend (Railway)
# Ejemplo: https://miapp.up.railway.app
BACKEND_URL=

# Dominio del frontend permitido por CORS.
# Puedes colocar varios separados por coma.
# Ejemplo: https://miapp.up.railway.app,https://www.midominio.com
FRONTEND_URL=

# Frontend (Vite):
# - En Railway con backend+frontend en la misma instancia, dejalo vacio.
# - En local, usa http://localhost:3001
VITE_API_URL=

# =========================
# DATABASE (MySQL)
# =========================
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# =========================
# AUTH
# =========================
JWT_SECRET=
SKIP_EMAIL_VERIFICATION=false

# =========================
# EMAIL (SMTP)
# =========================
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=
CONTACT_PHONE=

# =========================
# PAYU
# =========================
PAYU_API_LOGIN=
PAYU_API_KEY=
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_API_URL=https://sandbox.api.payulatam.com/payments-api/4.0/service.cgi
